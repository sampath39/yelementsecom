{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "set NODE_ENV=development && npm run build && npm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@react-google-maps/api": "^2.20.8",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5",
    "express-rate-limit": "^8.3.2",
    "nodemailer": "^8.0.4",
    "pdfkit": "^0.18.0",
    "pino": "^9",
    "pino-http": "^10",
    "razorpay": "^2.9.6",
    "stripe": "^21.0.1",
    "zod": "catalog:"
